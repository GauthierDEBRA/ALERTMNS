# ─────────────────────────────────────────────────────────────────────────────
# ALERTMNS — Variables d'environnement
# Copier ce fichier en .env et renseigner les valeurs avant de lancer Docker.
# ─────────────────────────────────────────────────────────────────────────────

# ── Sécurité JWT (OBLIGATOIRE) ────────────────────────────────────────────────
# Clé secrète HMAC pour signer les tokens. Doit faire AU MOINS 32 caractères.
# Générer une valeur sûre : openssl rand -hex 32
JWT_SECRET=change-me-to-a-long-random-secret-of-at-least-32-characters

# ── Base de données MySQL ─────────────────────────────────────────────────────
MYSQL_ROOT_PASSWORD=rootpass
MYSQL_DATABASE=alertmns
MYSQL_USER=alertmns
MYSQL_PASSWORD=alertmns

# ── Email (optionnel — Mailpit est utilisé en dev par défaut) ─────────────────
# Pour pointer vers un vrai serveur SMTP en production, décommenter et remplir :
# SPRING_MAIL_HOST=smtp.example.com
# SPRING_MAIL_PORT=587
# SPRING_MAIL_USERNAME=no-reply@example.com
# SPRING_MAIL_PASSWORD=motdepassesmtp
# SPRING_MAIL_SMTP_AUTH=true
# SPRING_MAIL_SMTP_STARTTLS=true

# ── Domaine et HTTPS (Caddy) ──────────────────────────────────────────────────
# En local, laisser "localhost" (certificat auto-signé Caddy).
# En prod, mettre votre domaine réel : Caddy obtiendra un certificat Let's Encrypt.
# Prérequis prod : ports 80 et 443 ouverts, DNS du domaine pointant sur ce serveur.
ALERTMNS_DOMAIN=localhost

# ── URLs application ──────────────────────────────────────────────────────────
# URL publique utilisée dans les emails (reset mdp, notifications).
# En local  : http://localhost
# En prod   : https://ton-domaine.com
ALERTMNS_APP_BASE_URL=http://localhost

# ── Cookie sécurisé ───────────────────────────────────────────────────────────
# Mettre "true" en prod (derrière HTTPS) pour activer le flag Secure sur le
# cookie de refresh token.
# En local HTTP, laisser "false" sinon le cookie n'est pas envoyé.
SERVER_USE_SECURE_COOKIE=false

# ── Expéditeur des emails ─────────────────────────────────────────────────────
ALERTMNS_MAIL_FROM=no-reply@alertmns.local
ALERTMNS_MAIL_FROM_NAME=ALERTMNS
ALERTMNS_MAIL_ENABLED=true
